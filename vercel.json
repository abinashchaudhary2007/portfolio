{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "server/app.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/app.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}